# ============================================================
# PaySentinelIQ — Environment Variables
# Copy to .env and fill in secrets for production
# ============================================================

# ── Application ──
APP_NAME=PaySentinelIQ
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ── Server ──
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# ── Database ──
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/paysentineliq

# ── Redis ──
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── JWT Auth ──
JWT_SECRET_KEY=change-me-in-production-use-256-bit-minimum-key
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AWS ──
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET=psi-documents

# ── AI / LLM Provider ──
# Provider selection: ollama (local, zero-cost), openai (cloud), anthropic, bedrock, groq, gemini
LLM_PROVIDER=ollama

# ── Ollama (Local LLM — Zero API Cost) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=120.0
OLLAMA_MAX_RETRIES=3
# OLLAMA_NUM_GPU=            # Auto-detect (set 0 for CPU-only)
# OLLAMA_NUM_THREAD=         # Auto-detect

# ── AI Shared Settings ──
AI_TEMPERATURE=0.1
AI_MAX_TOKENS=4096

# ── OpenAI (Cloud — optional, only if LLM_PROVIDER=openai) ──
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Sentry ──
SENTRY_DSN=https://your-sentry-key@oXXXXXX.ingest.us.sentry.io/XXXXXX

# ── Feature Flags ──
ENABLE_AI_AGENTS=false
ENABLE_OCR=false
ENABLE_COMPLIANCE_CHECKS=false
